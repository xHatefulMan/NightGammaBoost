<Window x:Class="NightGammaBoost.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:NightGammaBoost"
        Title="NightGammaBoost"
        Width="460"
        SizeToContent="Height"
        ResizeMode="CanMinimize"
        Background="{StaticResource BgBrush}"
        FontFamily="Segoe UI"
        Closing="Window_Closing">

    <Window.Resources>
        <Style x:Key="Section" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource PanelBrush}"/>
            <Setter Property="CornerRadius"    Value="8"/>
            <Setter Property="Padding"         Value="14,12"/>
            <Setter Property="Margin"          Value="0,0,0,8"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush2}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="STitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin"     Value="0,0,0,10"/>
        </Style>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="Foreground"        Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize"          Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="Sub" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="{StaticResource SubBrush}"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="Margin"       Value="0,2,0,0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="ScreenBtn" TargetType="Button">
            <Setter Property="Height"          Value="30"/>
            <Setter Property="MinWidth"        Value="140"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Margin"          Value="0,0,6,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="GameBtn" TargetType="Button">
            <Setter Property="Width"           Value="55"/>
            <Setter Property="Height"          Value="24"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <StackPanel Margin="14">

        <StackPanel Margin="0,0,0,12">
            <TextBlock Text="NightGammaBoost"
                       Foreground="{StaticResource AccentBrush}"
                       FontSize="22" FontWeight="SemiBold"/>
            <TextBlock Text="Boost de gamma automatique selon la luminosite du jeu"
                       Foreground="{StaticResource SubBrush}"
                       FontSize="11" Margin="0,3,0,0"/>
        </StackPanel>

        <Border Style="{StaticResource Section}" Padding="14,10">
            <StackPanel Orientation="Horizontal">
                <Ellipse x:Name="StatusDot" Width="8" Height="8"
                         Fill="{StaticResource RedBrush}"
                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock x:Name="StatusText" Text="Inactif"
                           Style="{StaticResource Lbl}" FontWeight="SemiBold"/>
            </StackPanel>
        </Border>

        <Border Style="{StaticResource Section}">
            <StackPanel>
                <TextBlock Text="OPTIONS" Style="{StaticResource STitle}"/>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Mode global" Style="{StaticResource Lbl}"/>
                        <TextBlock Text="Activer sur tout l'ecran en permanence"
                                   Style="{StaticResource Sub}"/>
                    </StackPanel>
                    <CheckBox x:Name="ChkGlobal" Grid.Column="1"
                              Style="{StaticResource ToggleStyle}"
                              VerticalAlignment="Center"/>
                </Grid>
                <Rectangle Height="1" Fill="{StaticResource BorderBrush2}" Margin="0,0,0,10"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Lancer au demarrage" Style="{StaticResource Lbl}"/>
                        <TextBlock Text="En arriere plan au demarrage Windows"
                                   Style="{StaticResource Sub}"/>
                    </StackPanel>
                    <CheckBox x:Name="ChkStartup" Grid.Column="1"
                              Style="{StaticResource ToggleStyle}"
                              VerticalAlignment="Center"
                              Checked="ChkStartup_Changed"
                              Unchecked="ChkStartup_Changed"/>
                </Grid>
            </StackPanel>
        </Border>

        <Border Style="{StaticResource Section}">
            <StackPanel>
                <TextBlock Text="REGLAGES" Style="{StaticResource STitle}"/>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Seuil de declenchement" Style="{StaticResource Lbl}"/>
                        <TextBlock Text="En dessous de ce niveau le boost s'active"
                                   Style="{StaticResource Sub}"/>
                    </StackPanel>
                    <Border Grid.Column="1" Background="#1E1E38" CornerRadius="4"
                            Padding="8,2" VerticalAlignment="Center">
                        <TextBlock x:Name="ThresholdVal" Text="15%"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontSize="12" FontWeight="SemiBold"/>
                    </Border>
                </Grid>
                <Slider x:Name="SliderThreshold" Style="{StaticResource SliderStyle}"
                        Minimum="5" Maximum="40" Value="15"
                        Margin="0,0,0,14" ValueChanged="SliderThreshold_Changed"/>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Intensite du boost" Style="{StaticResource Lbl}"/>
                        <TextBlock Text="Niveau de gamma applique quand le seuil est atteint"
                                   Style="{StaticResource Sub}"/>
                    </StackPanel>
                    <Border Grid.Column="1" Background="#1E1E38" CornerRadius="4"
                            Padding="8,2" VerticalAlignment="Center">
                        <TextBlock x:Name="BoostVal" Text="100%"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontSize="12" FontWeight="SemiBold"/>
                    </Border>
                </Grid>
                <Slider x:Name="SliderBoost" Style="{StaticResource SliderStyle}"
                        Minimum="10" Maximum="100" Value="100"
                        Margin="0,0,0,14" ValueChanged="SliderBoost_Changed"/>

                <Rectangle Height="1" Fill="{StaticResource BorderBrush2}" Margin="0,0,0,10"/>
                <TextBlock Text="Gauche : image au seuil  |  Droite : avec boost applique"
                           Style="{StaticResource Sub}" Margin="0,0,0,6"/>
                <Grid Height="120">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" CornerRadius="8" ClipToBounds="True">
                        <local:NightSceneControl x:Name="NightSceneThreshold" Brightness="0.08"/>
                    </Border>
                    <Border Grid.Column="2" CornerRadius="8" ClipToBounds="True">
                        <local:NightSceneControl x:Name="NightSceneBoost" Brightness="0.08"/>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>

        <Border Style="{StaticResource Section}">
            <StackPanel>
                <TextBlock Text="ECRANS" Style="{StaticResource STitle}"/>
                <WrapPanel x:Name="ScreenPanel"/>
            </StackPanel>
        </Border>

        <Border Style="{StaticResource Section}">
            <StackPanel>
                <TextBlock Text="JEUX DETECTES" Style="{StaticResource STitle}"/>
                <TextBlock Text="Active le boost automatiquement quand le jeu est lance"
                           Style="{StaticResource Sub}" Margin="0,0,0,8"/>
                <ScrollViewer MaxHeight="160">
                    <StackPanel x:Name="GamePanel"/>
                </ScrollViewer>
            </StackPanel>
        </Border>

    </StackPanel>
</Window>